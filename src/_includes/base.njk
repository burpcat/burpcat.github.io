<!DOCTYPE html>
<html lang="{{ site.language }}" data-theme="light"{% if page.url == "/about/" %} data-page="about"{% endif %}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#E7D3B8" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#0C1512" media="(prefers-color-scheme: dark)">
  <title>{% if title %}{{ title }} · {% endif %}{{ site.name }}</title>
  <meta name="description" content="{{ description or site.tagline }}">
  <link rel="alternate" type="application/rss+xml" title="{{ site.name }} RSS" href="/feed.xml">
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">
  <link href="https://api.fontshare.com/v2/css?f[]=clash-display@500,600,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">

  {# Anti-flash script — applies theme before paint #}
  <script>
    (function() {
      try {
        var saved = localStorage.getItem('theme');
        var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      } catch(e) {}
    })();
  </script>

  {% if "/blog/" in page.url %}
  {# Anti-flash script — applies reader mode before paint (blog + post pages only) #}
  <script>
    (function() {
      try {
        if (localStorage.getItem('reading-mode') === '1') {
          document.documentElement.classList.add('reading-mode');
        }
      } catch(e) {}
    })();
  </script>
  {% endif %}
</head>
<body>

{# ── BACKGROUND SCENE (fixed, site-wide) ── #}
<div class="scene" aria-hidden="true">
  <canvas class="scene-sky" id="sceneSky"></canvas>
  <div class="scene-ridge">
    <div class="ridge-far"></div>
    <div class="ridge-near"></div>
    <div class="ridge-trees"></div>
  </div>
</div>

<a href="#main" class="skip-link">skip to content</a>

<div class="wrap">

  {# ── UTILITY STRIP ── #}
  <div class="utility-strip glass-surface">
    <div class="status">
      <span class="dot" aria-hidden="true"></span>
      {% if github.configured and github.available %}
        <span class="label">currently building</span>
        <a href="{{ github.repoUrl }}" target="_blank" rel="noopener">{{ github.repoName }}</a>
        {% if github.description %}<span class="label">— {{ github.description }}</span>{% endif %}
      {% else %}
        <span class="label">{{ site.manualStatus }}</span>
      {% endif %}
    </div>
    <div class="tools">
      <button class="theme-switch" id="themeSwitch" aria-label="Toggle light and dark theme" type="button">
        <span class="theme-switch-knob">
          <span id="themeIcon" aria-hidden="true">☾</span>
        </span>
      </button>
      <button class="calm-toggle" id="calmToggle" aria-pressed="false" aria-label="Toggle calm mode" type="button">
        <span aria-hidden="true">◐</span>
        <span class="calm-label">calm mode</span>
      </button>
      <button class="mute-toggle" id="muteToggle" type="button" aria-label="Mute background music" hidden>♪</button>
      <span class="construction">★ under construction ★</span>
    </div>
  </div>

  {# ── HEADER ── #}
  <header class="glass-surface">
    <h1><a href="/">{{ site.nameDisplay | safe }}</a></h1>
    <p class="tagline">{{ site.tagline }}</p>
    <p class="sub-tagline"><span class="star" aria-hidden="true">★</span> {{ site.subTagline }} <span class="star" aria-hidden="true">★</span></p>

    <div class="nav-row">
      <nav aria-label="Main navigation">
        <a href="/" {% if page.url == "/" %}class="active" aria-current="page"{% endif %}>home</a>
        <a href="/blog/" {% if "/blog/" in page.url %}class="active" aria-current="page"{% endif %}>blog</a>
        <a href="/about/" {% if page.url == "/about/" %}class="active" aria-current="page"{% endif %}>about</a>
        <a href="/guestbook/" {% if page.url == "/guestbook/" %}class="active" aria-current="page"{% endif %}>guestbook</a>
        <a href="/feeds/" {% if page.url == "/feeds/" %}class="active" aria-current="page"{% endif %}>feeds</a>
        <a class="rss-link" href="/feed.xml" aria-label="RSS feed">
          <svg class="rss-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/></svg>
          rss
        </a>
      </nav>
      <div class="auth-buttons">
        <button class="btn" type="button" onclick="openModal('login')">log in</button>
        <button class="btn btn-primary" type="button" onclick="openModal('signup')">sign up</button>
      </div>
    </div>
  </header>

  {# ── HERO CAPTION (homepage only, floats over the scene) ── #}
  {% if page.url == "/" %}
  <p class="hero-caption">a small bright thing in a vast quiet space</p>
  {% endif %}

  {{ content | safe }}

  <footer class="glass-surface">
    <p> coded on aegon · no analytics OR tracking </p>
    <p><a href="/feed.xml">rss</a> · <a href="/guestbook/">guestbook</a></p>
  </footer>

</div>

{# ── auth modal (placeholder) ── #}
<div class="modal-backdrop" id="authModal" onclick="if(event.target===this)closeModal()" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
  <div class="modal glass-surface">
    <h3 id="modalTitle">log in</h3>
    <p id="modalDesc">Welcome back. Pick up where you left off.</p>
    <input type="email" placeholder="email" aria-label="Email">
    <input type="password" placeholder="password" aria-label="Password">
    <div class="modal-actions">
      <button class="btn btn-primary" type="button">continue</button>
      <button class="modal-close" type="button" onclick="closeModal()">cancel</button>
    </div>
  </div>
</div>

<audio id="calmAudio" src="/audio/flowers-of-the-forest.mp3" loop preload="none"></audio>

<script src="/js/site.js"></script>
<script src="/js/spiral.js"></script>
</body>
</html>
