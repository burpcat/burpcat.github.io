---
layout: base.njk
---
<main id="main">
<article class="post-full">

  <header>
    <div class="post-meta-row" style="justify-content: space-between;">
      <div class="post-meta-row" style="margin-bottom: 0;">
        <time class="post-date" datetime="{{ page.date | isoDate }}">{{ page.date | dotDate }}</time>
        <span class="reading-time">{{ content | readingTime }}</span>
      </div>
      <button class="reader-toggle glass-surface" id="readerToggle" aria-pressed="false" type="button">
        <span class="calm-icon" aria-hidden="true">❧</span>
        <span class="reader-label">reader view</span>
      </button>
    </div>
    <h1 class="post-full-title">{{ title }}</h1>
    {% if tags and (tags | displayTags).length %}
    <div class="post-tags">
      {% for tag in tags | displayTags %}<span class="tag-pill">{{ tag }}</span>{% endfor %}
    </div>
    {% endif %}
  </header>

  {% if coverImage %}
  <figure class="post-cover">
    <img src="{{ coverImage }}" alt="{{ coverImageAlt or title }}">
  </figure>
  {% endif %}

  <div class="post-body glass-surface">
    {{ content | safe }}
  </div>

  <div class="post-footer">
    <a class="back-link" href="/blog/">← back to all writing</a>
  </div>

</article>
</main>
